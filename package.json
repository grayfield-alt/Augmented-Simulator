{
  "name": "augmented_simulator_web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:deploy": "vite build && node scripts/sync-dist.js",
    "deploy": "npm run build && node scripts/smoke-check.js && npx gh-pages -d dist",
    "postbuild": "node -e \"const fs=require('fs'); if(fs.existsSync('dist/index.html')) fs.copyFileSync('dist/index.html', 'dist/proto2.html')\"",
    "smoke-check": "node scripts/smoke-check.js",
    "check": "npm run lint && npm run build",
    "prepare": "node scripts/setup-hooks.js",
    "handoff": "node -e \"require('child_process').spawn(process.platform==='win32'?'clip':'pbcopy').stdin.end('git pull 받았어. 프로젝트 루트에 있는 HANDOFF.md 파일 읽고 하던 작업 이어서 해줘.')\"",
    "lint": "eslint src/main.ts src/core src/ui src/utils --no-error-on-unmatched-pattern",
    "preview": "vite preview"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^7.3.1"
  }
}